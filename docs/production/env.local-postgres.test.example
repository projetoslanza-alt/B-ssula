# Ambiente de validação local PostgreSQL — NÃO commitar .env.local-postgres.test

APP_ENV=production
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

AUTH_PROVIDER=local
NEXT_PUBLIC_AUTH_PROVIDER=local
DATABASE_PROVIDER=local_postgres
NEXT_PUBLIC_DATABASE_PROVIDER=local_postgres
STORAGE_DRIVER=local
NEXT_PUBLIC_STORAGE_DRIVER=local

# PostgreSQL de validação (Docker: scripts/setup-local-validation-db.ps1)
DATABASE_URL=postgresql://bussola_admin_validation:bussola_val_test@localhost:5434/bussola_local_validation
DIRECT_DATABASE_URL=postgresql://bussola_admin_validation:bussola_val_test@localhost:5434/bussola_local_validation

# Gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
AUTH_SECRET=CHANGE_ME_AUTH_SECRET_48_BYTES_MIN
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_48_BYTES_MIN
PASSWORD_PEPPER=CHANGE_ME_PASSWORD_PEPPER

STORAGE_LOCAL_PATH=.local/validation-uploads

# Bootstrap (não commitar senha real)
BOOTSTRAP_ADMIN_EMAIL=admin.local.validation@bussola.test
BOOTSTRAP_ADMIN_NAME=Admin Validação Local
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD_12_CHARS
BOOTSTRAP_ORGANIZATION_NAME=Empresa Validação Local
BOOTSTRAP_ORGANIZATION_SLUG=empresa-validacao-local
PRODUCTION_TENANT_SLUG=empresa-validacao-local
PRODUCTION_CONFIRMATION=

# QA local (credenciais geradas em .local/local-postgres-qa.json — gitignored)
QA_MANAGER_EMAIL=gerente.validacao@bussola.test
QA_SDR_EMAIL=sdr.validacao@bussola.test
QA_CLOSER_EMAIL=closer.validacao@bussola.test
